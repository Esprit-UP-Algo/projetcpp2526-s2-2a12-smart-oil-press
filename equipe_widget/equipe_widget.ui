                        </layout>
               </item>
               <item>
                <widget class="QLabel" name="taskInstructionLabel">
                 <property name="text">
                           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-size:11px; color:#808080; font-style:italic;&quot;&gt;• Utilisez le bouton &quot;Ajouter une tâche&quot; pour ajouter une nouvelle tâche pour une équipe spécifique sélectionnée par ID&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-size:11px; color:#808080; font-style:italic;&quot;&gt;• Maximum 3 tâches en cours par équipe&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-size:11px; color:#808080; font-style:italic;&quot;&gt;• Cochez la case devant la tâche pour marquer celle-ci comme complète&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-size:11px; color:#808080; font-style:italic;&quot;&gt;• Sélectionnez une ligne puis cliquez sur &quot;Supprimer tâche&quot; (ne compte ni comme succès ni comme échec)&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
                 </property>
                 <property name="wordWrap">
                  <bool>true</bool>
                 </property>
                 <property name="alignment">
                  <set>Qt::AlignTop</set>
                 </property>
                </widget>
