                      <string>Bienvenue dans l'application de gestion</string>
                    </property>
                    <property name="alignment">
                      <set>Qt::AlignCenter</set>
                    </property>
                  </widget>
                </item>
              </layout>
            </widget>
            <widget class="QWidget" name="pageAccueil">
              <layout class="QVBoxLayout" name="accueilLayout">
                <property name="leftMargin">
                  <number>60</number>
                </property>
                <property name="rightMargin">
                  <number>60</number>
                </property>
                <item>
                  <spacer name="accueilTopSpacer">
                    <property name="orientation">
                      <enum>Qt::Vertical</enum>
                    </property>
                  </spacer>
                </item>
                <item>
                  <widget class="QLabel" name="accueilTitre">
                    <property name="text">
                      <string>🌿 Bienvenue sur Smart Oil Management</string>
                    </property>
                    <property name="alignment">
                      <set>Qt::AlignCenter</set>
                    </property>
                    <property name="styleSheet">
                      <string>font-size: 28px; font-weight: bold; color: #2E7D32; margin-bottom: 20px;</string>
                    </property>
                  </widget>
                </item>
                <item>
                  <widget class="QLabel" name="accueilMessage">
                    <property name="text">
                      <string>Votre solution complète pour la gestion intelligente de votre huilerie.

Gérez efficacement vos employés, équipes, clients, commandes, laboratoires et machines
depuis une interface moderne et intuitive.

Optimisez votre production, suivez vos analyses qualité et prenez des décisions
éclairées grâce à nos outils de statistiques modernes.</string>
                    </property>
                    <property name="alignment">
                      <set>Qt::AlignCenter</set>
                    </property>
                    <property name="wordWrap">
                      <bool>true</bool>
                    </property>
                    <property name="styleSheet">
                      <string>font-size: 16px; color: #555; line-height: 1.6; margin: 30px 0;</string>
                    </property>
                  </widget>
                </item>
                <item>
