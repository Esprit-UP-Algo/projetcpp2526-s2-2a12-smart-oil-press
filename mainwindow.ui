        <item>
          <widget class="QStackedWidget" name="stackedMain">
            <widget class="QWidget" name="pagePlaceholder">
              <attribute name="title">
                <string>Accueil</string>
              </attribute>
              <layout class="QVBoxLayout" name="verticalLayout_placeholder">
                <item>
